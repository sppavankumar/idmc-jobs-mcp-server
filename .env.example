# ─── Informatica IDMC Credentials ────────────────────────────────────────────
# Option A: username + password (server will auto-login on startup)
IDMC_USERNAME=your-email@example.com
IDMC_PASSWORD=your-password

# Login base URL – change to match your pod/region
# Examples:
#   https://dm-us.informaticacloud.com      (US)
#   https://dm-eu.informaticacloud.com      (EU)
#   https://dm-ap.informaticacloud.com      (APAC)
#   https://dm1-ap.informaticacloud.com     (APAC pod 1)
IDMC_BASE_URL=https://dm-us.informaticacloud.com

# Option B: provide a pre-existing session (overrides A if both set)
# IDMC_SERVER_URL=https://usw3.dm-us.informaticacloud.com/saas
# IDMC_SESSION_ID=9KA11tLGqxVcGeul8SABC1
